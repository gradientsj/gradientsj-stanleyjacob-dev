flowchart LR
    ENV["PushT simulator"] -- "96x96 camera image<br/>+ pusher position" --> PRE["Preprocessor<br/>normalize with<br/>training statistics"]
    PRE --> POL["Diffusion policy<br/>denoises a 16-step action chunk,<br/>conditioned on the last 2 observations"]
    POL --> POST["Postprocessor<br/>unnormalize back to<br/>pixel coordinates"]
    POST -- "execute the first 8 actions,<br/>then replan" --> ENV
