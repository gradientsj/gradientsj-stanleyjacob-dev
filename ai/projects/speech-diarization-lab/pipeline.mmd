flowchart TD
    AUDIO[/"audio file"/] --> ASR["faster-whisper (CTranslate2)<br/>words + timestamps"]
    AUDIO --> VAD["silero VAD<br/>speech regions"]
    VAD --> EMB["ECAPA speaker embeddings<br/>1.5 s windows, 0.75 s stride"]
    EMB --> CLU["agglomerative clustering<br/>cosine, average linkage"]
    CLU --> TRN["speaker turns"]
    ASR --> ALN["alignment<br/>words assigned by max overlap"]
    TRN --> ALN
    ALN --> OUT[/"speaker-attributed<br/>JSON / SRT / RTTM"/]